# Supabase Configuration
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Marketing Hero Demo Video
# Public URLs to the hero video and its thumbnail, stored in Supabase Storage
# (bucket: marketing-assets). Example shapes:
#   https://<project>.supabase.co/storage/v1/object/public/marketing-assets/demo-hero.mp4
#   https://<project>.supabase.co/storage/v1/object/public/marketing-assets/demo-hero-thumbnail.jpg
# If POSTER_URL is omitted, the existing local hero JPG is used as a fallback.
NEXT_PUBLIC_DEMO_VIDEO_URL=""
NEXT_PUBLIC_DEMO_VIDEO_POSTER_URL=""

# Gemini AI Configuration
# Get your API key from: https://aistudio.google.com/app/apikey
# Note: This is server-side only (no NEXT_PUBLIC_ prefix for security)
ENGINE_API_KEY="your-engine-api-key-here"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key-here"

# Detection v2 (YOLOv8 + SAM + PaddleOCR)
# Feature flag — set to "true" to enable the /api/detect/* proxy routes and the
# detection-driven wizard/report.
NEXT_PUBLIC_DETECTION_V2="false"

# Backend provider: "fastapi" for self-hosted container (ECS/ACA/SageMaker) or
# "replicate" for Replicate's async predictions API.
DETECTION_PROVIDER="fastapi"

# FastAPI provider settings
DETECTION_BASE_URL="https://detection.example.com"
DETECTION_BEARER_TOKEN="shared-secret-matching-HOMINGO_SERVICE_TOKEN"

# Replicate provider settings
REPLICATE_API_TOKEN=""
REPLICATE_MODEL_VERSION=""

# Resend — transactional email for the /api/contact route.
# Sign up at https://resend.com, verify the homingo.co.uk sender domain
# (Resend gives you SPF + DKIM DNS records to add), then create an API key
# and paste it below.
RESEND_API_KEY=""
CONTACT_FROM_EMAIL="noreply@accesscheck.co.uk"
CONTACT_TO_EMAIL="info@accesscheck.co.uk"

# ---------------------------------------------------------------------------
# Evidence Harvester
# ---------------------------------------------------------------------------
# Service-role key (server-only, NO NEXT_PUBLIC_ prefix). Used by the harvest
# background worker, which runs detached from the request and bypasses RLS, so
# it sets user_id explicitly on every write. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=""

# EPC API — "Get energy performance of buildings data" service.
# Auth is a Bearer token: put the token in EPC_API_KEY. Register and generate a token at
# https://get-energy-performance-data.communities.gov.uk/ (see /api-technical-documentation).

EPC_API_KEY=""
EPC_API_BASE_URL="https://api.get-energy-performance-data.communities.gov.uk"

# Postcodes.io — free, no key required.
POSTCODES_IO_BASE_URL="https://api.postcodes.io"

# HM Land Registry Price Paid (free sale-transaction history).
LAND_REGISTRY_PPD_BASE_URL="https://landregistry.data.gov.uk"

# Optional rental/portal listing provider. Empty = sale history only (no scraping).
LISTING_PROVIDER=""
LISTING_PROVIDER_API_KEY=""

# Google Street View (Phase 2). Server-only key for metadata/image calls.
# Both flags must be "true" before any paid image request is made.
GOOGLE_MAPS_SERVER_API_KEY=""
GOOGLE_STREET_VIEW_ENABLED="false"
GOOGLE_STREET_VIEW_FETCH_IMAGES="false"

# Vision model for exterior analysis (reuses ENGINE_API_KEY above).
ENGINE_VISION_MODEL="gemini-2.5-flash"

# Harvest batching — items processed per resumable background batch.
HARVEST_BATCH_SIZE="100"
HARVEST_MAX_CONCURRENCY="3"