{
  "$source": "Maps LAHR business-rules variable names to our Supabase `surveys` table columns. Used by the criterion evaluators and the question-graph engine to read/write per-field values.",
  "$see_also": "types/supabase.ts",
  "mapping": {
    "Postcode": "postcode",
    "PropertyOwner": "tenure_type",
    "HousingAssName": "housing_association_name",
    "PropertyEntryLevel": {
      "column": "entrance_level",
      "values": { "Ground": "Ground Floor", "Other": "Upper Floor", "Basement": "Basement" }
    },
    "NoofBedrooms": "num_bedrooms",
    "NoofBeds": { "column": "num_bed_spaces", "fallback_column": "num_bedrooms", "note": "LAHR 'beds' means bed-spaces (person capacity); falls back to bedrooms if unknown" },
    "NoofLifts": "num_lifts_dwelling",
    "NumofLift": "num_lifts_dwelling",
    "InternalStairs": { "column": "has_internal_stairs", "bool_as_yes_no": true },
    "StraightStairs": { "column": "has_straight_stairs", "bool_as_yes_no": true },
    "CurvedStairs": { "column": "has_curved_stairs", "bool_as_yes_no": true },
    "WidthofStairs": "stair_width_cm",
    "WidthofStairs1": "stair_width_cm",
    "MoreThan70cm": { "column": "stair_70cm_clearance", "bool_as_yes_no": true },
    "InternalSteps": "internal_steps_count",
    "CommunalFrontDoor": { "column": "has_communal_front_door", "bool_as_yes_no": true },
    "CommunalFrontDoorNumSteps": "communal_door_steps_count",
    "CommunalFrontDoorWidth": { "column": "communal_door_opening_width", "unit": "cm" },
    "CommunalFrontDoorThreshold": {
      "column": "communal_door_threshold_height",
      "values": { "Level": "level", "LessThan1_5": "<1.5cm", "10_to_1_5": "1.5-10cm", "MoreThan10": ">10cm" }
    },
    "CommunalNumSteps": "communal_door_steps_count",
    "CommunalRamp": { "column": "has_communal_ramp", "bool_as_yes_no": true },
    "CommunalRampPlatform": { "column": "communal_ramp_adequate_platform", "bool_as_yes_no": true },
    "CommunalRampGradient": { "derived_from": ["communal_ramp_ah", "communal_ramp_al"], "formula": "gradient_percent = (ah/al) * 100", "unit": "percent" },
    "CommunalRampLength": { "derived_from": ["communal_ramp_al", "communal_ramp_bl"], "unit": "cm" },
    "CommunalRampType": "$question_only — not in surveys yet",
    "PropertyFrontDoor": "has_property_front_door",
    "PropertyFrontDoorNumSteps": "property_door_steps_count",
    "PropertyNumSteps": "property_door_steps_count",
    "PropertyFrontDoorWidth": { "column": "property_door_opening_width", "unit": "cm" },
    "PropertyFrontDoorThreshold": {
      "column": "property_door_threshold_height",
      "values": { "Level": "level", "LessThan1_5": "<1.5cm", "10_to_1_5": "1.5-10cm", "MoreThan10": ">10cm" }
    },
    "PropertyRamp": { "column": "has_property_ramp", "bool_as_yes_no": true },
    "PropertyRampPlatform": { "column": "property_ramp_adequate_platform", "bool_as_yes_no": true },
    "PropertyRampGradient": { "derived_from": ["property_ramp_ah", "property_ramp_al"], "formula": "gradient_percent = (ah/al) * 100", "unit": "percent" },
    "PropertyRampLength": { "derived_from": ["property_ramp_al", "property_ramp_bl"], "unit": "cm" },
    "SecondExit": "has_second_exit",
    "SecondExitAccesstoStreet": "has_second_exit",
    "SecondExitNumSteps": "second_exit_steps_count",
    "SecondExitDoorWidth": { "column": "second_exit_door_width", "unit": "cm" },
    "SecondExitThreshold": {
      "column": "second_exit_threshold_height",
      "values": { "Level": "level", "LessThan1_5": "<1.5cm", "10_to_1_5": "1.5-10cm", "MoreThan10": ">10cm" }
    },
    "SecondExitRamp": { "column": "has_ramped_second_exit", "bool_as_yes_no": true },
    "SecondExitRampPlatform": { "column": "second_exit_ramp_platform", "bool_as_yes_no": true },
    "SecondExitRampGradient": { "derived_from": ["second_exit_ramp_ah", "second_exit_ramp_al"], "formula": "gradient_percent = (ah/al) * 100", "unit": "percent" },
    "SecondExitRampLength": { "derived_from": ["second_exit_ramp_al", "second_exit_ramp_bl"], "unit": "cm" },
    "CommunalLift": { "column": "has_communal_lift", "bool_as_yes_no": true },
    "DoorOpeningWidth": { "column": "communal_lift_door_width", "unit": "cm" },
    "ServicingLiftInternalDimensionsA": { "column": "communal_lift_dim_width", "unit": "cm" },
    "ServicingLiftInternalDimensionsB": { "column": "communal_lift_dim_depth", "unit": "cm" },
    "ThroughFloorLift": { "column": "has_through_floor_lift", "bool_as_yes_no": true },
    "ThroughFloorLiftDimensionsA": { "column": "through_floor_lift_dim_width", "unit": "cm" },
    "ThroughFloorLiftDimensionsB": { "column": "through_floor_lift_dim_depth", "unit": "cm" },
    "PlatformLift": { "column": "has_platform_stair_lift", "bool_as_yes_no": true },
    "HallwayHead": "hallway_width_head_on_cm",
    "HallwayHead1": "hallway_width_head_on_cm",
    "HallwayTurn": "hallway_width_turn_cm",
    "HallwayTurn1": "hallway_width_turn_cm",
    "BedOne1": "door_width_bed1",
    "BedTwo1": "door_width_bed2",
    "BedThree1": "door_width_bed3",
    "Kitchen1": "door_width_kitchen",
    "Bathroom1": "door_width_bathroom",
    "SeparateToilet1": "door_width_separate_toilet",
    "Lounge1": "door_width_living_room",
    "TurningSpaceWheelchair": "kitchen_turning_150x150",
    "LargerTurningSpaceWheelchair": "kitchen_turning_170x140",
    "BathroomTurningSpaceWheelchair": "bathroom_turning_150x150",
    "LevelAccessShower": "bathroom_has_level_access_shower",
    "SeparateToilet": { "column": "has_separate_toilet", "bool_as_yes_no": true },
    "SeparateToiletA": "toilet_dim_width",
    "SeparateToiletB": "toilet_dim_depth",
    "ToiletSideWallSpace": "toilet_lateral_space_cm",
    "CombToiletSideWallSpace": "bathroom_toilet_lateral_space",
    "WheelchairScooterStorage": { "column": "has_wheelchair_storage", "bool_as_yes_no": true },
    "WheelchairScooterStorageA": "wheelchair_storage_dim_width",
    "WheelchairScooterStorageB": "wheelchair_storage_dim_depth",
    "FacilitiesAccessLevelBed1": "access_bed1",
    "FacilitiesAccessLevelBed2": "access_bed2",
    "FacilitiesAccessLevelBathroom": "access_bathroom_no_toilet",
    "FacilitiesAccessLevelSepToilet": "access_separate_toilet",
    "FacilitiesAccessLevelCombBathroom": "access_combined_bath_toilet",
    "FacilitiesAccessLevelCombBathToilet": "access_combined_bath_toilet",
    "FacilitiesAccessLevelLivingRoom": "access_living_room",
    "FacilitiesAccessLevelKitchen": "access_kitchen",
    "NoEntranceGroundandNoLift": { "$derived": true, "from": "stop_flag_no_lift_or_ramp" },
    "SectionDEnd": { "$derived": true, "from_any": ["stop_flag_too_many_steps"] },
    "SectionEEnd1": { "$derived": true, "from_any": ["stop_flag_internal_steps"] },
    "SectionEEnd2": { "$derived": true, "from_any": ["stop_flag_stair_width"] },
    "OtherPropertiesAssessed": "is_multiple_properties",
    "OtherUPRN_1": "$question_only",
    "OtherUPRN_2": "$question_only"
  },
  "not_yet_in_schema": [
    "CommunalRampType / PropertyRampType / SecondExitRampType — concrete ramp type enum (straight, dog-leg, etc.)",
    "second_exit_door_width — referenced by rule 42/43; check column name in surveys",
    "second_exit_threshold_height — referenced by rule 33; check column name",
    "access_living_room — referenced by rule 45/70; some schemas call this `living_room` under the facilities-access block",
    "num_bed_spaces — referenced by rules 65/66; some schemas call this occupancy_capacity"
  ]
}
